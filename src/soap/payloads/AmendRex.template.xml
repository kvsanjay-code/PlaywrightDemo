            <!-- same structure as LodgeRex attachments -->
         </amen:attachments>
         <!--Optional:-->
         <amen:additionalTexts>
            <!-- same structure as LodgeRex additionalTexts -->
         </amen:additionalTexts>
         <!--Optional:-->
         <amen:euTransit>
            <!-- same structure as LodgeRex euTransit -->
