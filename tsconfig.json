{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "src/*":       ["./src/*"],
      "test-data/*": ["./test-data/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "test-data/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
